    },
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "start": "yarn format && yarn lint && yarn type-check && vite",
        "build": "vite build",
        "image": "cross-conf-env docker build -t $npm_package_name:$npm_package_version -f Dockerfile .",
        "preview": "vite preview --host",
        "format": "prettier --write . --config ./.prettierrc.json",
        "lint": "eslint  ./src --fix --flag unstable_ts_config",
        "type-check": "vue-tsc --noEmit --composite false"
    },
    "husky": {
        "hooks": {
            "pre-commit": "yarn format && yarn lint && yarn type-check"
        }
    },
    "homepage": "https://github.com/yangxj96/spectra-web",
    "keywords": [
        "SAAS",
        "VUE"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/yangxj96/spectra-web"
    },
    "bugs": {
        "email": "yangxj96@gmail.com",
        "url": "https://github.com/yangxj96/spectra-web/issues"
    },
    "dependencies": {
        "@stomp/stompjs": "7.1.0",
        "@vueuse/core": "13.0.0",
        "axios": "1.8.4",
        "crypto-js": "4.2.0",
        "element-plus": "2.9.7",
        "follow-redirects": "1.15.9",
        "highlight.js": "11.11.1",
        "pinia": "2.3.1",
        "pinia-plugin-persistedstate": "4.2.0",
        "sass": "1.86.0",
        "vkbeautify": "0.99.3",
